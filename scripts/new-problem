#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"

usage() {
  echo "Usage: scripts/new-problem <contest> <task-id> <url>" >&2
}

if [ "$#" -eq 1 ] && [ "$1" = "--help" ]; then
  usage
  exit 0
fi

if [ "$#" -ne 3 ]; then
  usage
  exit 1
fi

contest="$1"
task_id="$2"
url="$3"

problem_dir="$REPO_ROOT/practice/atcoder/$contest/$task_id"

require_command "cargo" "cargo が見つかりません。Rust stable を有効にしてください: rustup default stable"
require_command "oj" "oj が見つかりません。先に実行してください: nix --extra-experimental-features \"nix-command flakes\" develop"

mkdir -p "$problem_dir"

created_cargo=0
if [ ! -f "$problem_dir/Cargo.toml" ]; then
  cargo init --bin "$problem_dir"
  created_cargo=1
fi

main_file="$problem_dir/src/main.rs"
if [ "$created_cargo" -eq 1 ] || [ ! -f "$main_file" ]; then
  cat > "$main_file" <<'EOF'
use std::io::{self, Read};

struct Scanner {
    input: Vec<String>,
    index: usize,
}

impl Scanner {
    fn new() -> Self {
        let mut input = String::new();
        io::stdin().read_to_string(&mut input).unwrap();
        let input = input.split_whitespace().map(|s| s.to_string()).collect();

        Scanner { input, index: 0 }
    }

    fn next<T: std::str::FromStr>(&mut self) -> T {
        let value = self.input[self.index].parse::<T>().ok().unwrap();
        self.index += 1;
        value
    }
}

fn main() {
    let mut sc = Scanner::new();

    // TODO: implement
    let _ = &mut sc;
}
EOF
else
  echo "Kept existing: $main_file"
fi

(
  cd "$problem_dir"
  oj d "$url"
)

printf '%s\n' "$url" > "$problem_dir/.atcoder-task-url"

echo "Created: $problem_dir"
echo
echo "Next:"
echo "  cd $problem_dir"
echo "  \$EDITOR src/main.rs"
echo "  at-test"
echo "  at-submit  # ブラウザ提出用の情報を表示"
