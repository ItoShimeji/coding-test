#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"

usage() {
  echo "Usage: scripts/test [<contest> <task-id>]" >&2
}

if [ "$#" -eq 1 ] && [ "$1" = "--help" ]; then
  usage
  exit 0
fi

if ! problem_dir="$(resolve_problem_dir "$@")"; then
  usage
  exit 1
fi

require_file "$problem_dir/Cargo.toml" "Cargo.toml not found: $problem_dir"
require_command "oj" "oj が見つかりません。先に実行してください: nix --extra-experimental-features \"nix-command flakes\" develop"
require_command "cargo" "cargo が見つかりません。Rust stable を有効にしてください: rustup default stable"

(
  cd "$problem_dir"
  oj t -c "cargo run --quiet"
)
