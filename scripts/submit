#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"

usage() {
  echo "Usage: scripts/submit [<contest> <task-id>]" >&2
}

if [ "$#" -eq 1 ] && [ "$1" = "--help" ]; then
  usage
  exit 0
fi

if ! problem_dir="$(resolve_problem_dir "$@")"; then
  usage
  exit 1
fi

require_file "$problem_dir/Cargo.toml" "Cargo.toml not found: $problem_dir"
require_file "$problem_dir/src/main.rs" "src/main.rs not found: $problem_dir"

task_url=""
if [ -f "$problem_dir/.atcoder-task-url" ]; then
  IFS= read -r task_url < "$problem_dir/.atcoder-task-url" || true
fi

if [ -z "$task_url" ]; then
  die ".atcoder-task-url not found or empty: $problem_dir"
fi

contest_id="${task_url#https://atcoder.jp/contests/}"
contest_id="${contest_id%%/*}"
task_id="${task_url##*/}"
submit_url="https://atcoder.jp/contests/$contest_id/submit"

cat <<EOF
ブラウザで提出してください。

URL:    $submit_url
問題:   $task_id
言語:   Rust
提出元: $problem_dir/src/main.rs

提出前に確認:
  at-test
EOF
